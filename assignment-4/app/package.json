{
  "name": "devops-a4-app",
  "version": "1.0.0",
  "description": "Sample Express app for DevOps Assignment 4",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit --coverage --coverageDirectory=coverage/unit",
    "test:integration": "jest tests/integration --coverage --coverageDirectory=coverage/integration"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^6.3.4",
    "sonar-scanner": "^3.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageReporters": ["lcov", "text"],
    "coverageDirectory": "coverage",
    "reporters": [
      "default",
      ["jest-junit", { "outputDirectory": ".", "outputName": "junit.xml" }]
    ]
  }
}
